<% layout("/layouts/boilerplate") %>

<head>
  <title>Contributor Dashboard</title>
  <link rel="stylesheet" href="/css/style.css" />

  <style>
    body {
      background: #f6f8fc;
      font-family: "Segoe UI", sans-serif;
    }

    .main-content {
      padding: 40px 0;
    }

    /* HEADER */
    header {
      background: #ffffff;
      padding: 15px 40px;
      border-bottom: 1px solid #e6e9ef;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-size: 20px;
      font-weight: 700;
      color: #0072ff;
    }

    .user-name {
      font-weight: 600;
      color: #333;
      margin-left: 10px;
    }

    nav a {
      margin-left: 25px;
      text-decoration: none;
      color: #444;
      font-weight: 500;
      position: relative;
    }

    nav a::after {
      content: "";
      position: absolute;
      width: 0%;
      height: 2px;
      bottom: -4px;
      left: 0;
      background: #0072ff;
      transition: 0.3s;
    }

    nav a:hover::after {
      width: 100%;
    }

    nav a:hover {
      color: #0072ff;
    }

    /* TITLE */
    .section-title {
      font-weight: 700;
      margin-bottom: 25px;
      color: #222;
    }

    /* CARD */
    .news-card {
      background: #ffffff;
      border-radius: 16px;
      padding: 22px;
      margin-bottom: 25px;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.05);
      transition: all 0.25s ease;
    }

    .news-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.1);
    }

    .news-card img {
      border-radius: 12px;
      object-fit: cover;
      max-height: 260px;
    }

    .news-card h3 {
      font-weight: 600;
      margin-top: 15px;
      color: #222;
    }

    .news-card p {
      color: #555;
      line-height: 1.6;
      font-size: 15px;
    }

    /* AUTHOR */
    .author {
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
      color: #333;
    }

    /* META */
    .meta {
      font-size: 13px;
      color: #888;
    }

    /* BUTTON */
    .btn {
      border-radius: 25px;
      padding: 8px 24px;
      background: #0072ff;
      border: none;
      font-size: 14px;
      transition: 0.3s;
    }

    .btn:hover {
      background: #005edb;
      transform: scale(1.05);
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.15);
    }

    /* EMPTY */
    .empty-box {
      background: #ffffff;
      padding: 50px;
      border-radius: 15px;
      text-align: center;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.05);
    }

    .empty-box h4 {
      color: #777;
      margin-bottom: 10px;
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      header {
        flex-direction: column;
        align-items: flex-start;
      }

      nav {
        margin-top: 10px;
      }

      .main-content {
        padding: 20px;
      }
    }
  </style>
</head>

<body>

  <!-- HEADER -->
  <header>
    <div>
      <span class="logo">NationMantra</span>
      <span class="user-name">| <%= user.name %></span>
    </div>

    <nav>
      <a href="/">Home</a>
      <a href="/news/new">Create</a>
      <a href="/auth/logout">Logout</a>
    </nav>
  </header>

  <div class="main-content">
    <div class="col-lg-8 offset-lg-2">

      <!-- TITLE -->
      <h2 class="section-title">Your Stories</h2>

      <% if(!posts || posts.length === 0){%>
        <div class="empty-box">
          <h4>No stories published</h4>
          <p class="text-muted">Start creating content</p>
        </div>
      <%}%>

      <% posts.forEach(news => { %>
      <div class="news-card">

        <!-- AUTHOR -->
        <div class="author">
          <%= news.author.name %>
          <img src="/image/tick.svg" width="14"/>
        </div>

        <!-- IMAGE -->
        <div class="mt-3">
          <img
            class="w-100 img-fluid"
            src="<%=news.image.url%>"
            alt="news"
          />
        </div>

        <!-- TITLE -->
        <h3><%= news.title %></h3>

        <% const newsURL = `http://localhost:8080/news/${news._id}`; 
        const shareText = encodeURIComponent(`${news.title} - Read more: ${newsURL}`); %>

        <!-- META -->
        <div class="meta">
          <%= news.category %> • <%= news.timestamp.toDateString() %>
        </div>

        <!-- CONTENT -->
        <p><%= news.content.substring(0, 100) %>...</p>

        <!-- BUTTON -->
        <div class="text-center mt-3">
          <button
            class="btn text-light"
            onclick="window.location.href='/news/article/<%= news._id %>'"
          >
            Read Article
          </button>
        </div>

      </div>
      <% }) %>

    </div>
  </div>

</body>